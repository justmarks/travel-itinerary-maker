# Server
PORT=3001
NODE_ENV=development
# Comma-separated list of literal allowed origins.
CORS_ORIGIN=http://localhost:3000
# Optional regex (as a string) for dynamic origins like Vercel preview
# URLs. A request is allowed if its Origin matches any literal in
# CORS_ORIGIN OR this pattern. Leave unset in dev.
# Example for this project's preview deploys:
# CORS_ORIGIN_PATTERN=^https://itinly-[a-z0-9-]+-justmarks-projects\.vercel\.app$

# Google OAuth (create at https://console.cloud.google.com/apis/credentials).
# The redirect URI used by the web flow is built at runtime from the
# browser origin (`<origin>/auth/callback`) — register it in the Google
# Cloud Console for each origin you serve from (dev: http://localhost:3000,
# prod: your Vercel origin). No GOOGLE_REDIRECT_URI env var needed.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Anthropic API (for email parsing)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Upstash Redis (optional but recommended for production).
# When both are set, the server persists refresh tokens and share-link
# entries so they survive process restarts. Get these from
# Upstash Console → Databases → REST API. They are per-database
# credentials; do NOT use the account / management API key.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-rest-token

# At-rest encryption for refresh tokens stored in Redis. When set, the
# `refreshToken` field of each persisted entry is AES-256-GCM-encrypted
# so a Redis dump alone isn't enough to grant access to user accounts.
# Generate with: openssl rand -hex 32  (must be exactly 64 hex chars).
# Leave unset to fall through to plaintext storage (fine for dev/tests,
# not recommended for production). Rotating the key invalidates all
# existing entries — affected users will have to sign in again.
TOKEN_ENCRYPTION_KEY=

# Web Push (RFC 8292 / VAPID). Required to deliver share-invite and
# trip-activity push notifications. Generate once with:
#   npx web-push generate-vapid-keys
# Persist both halves; the public half also goes into the frontend
# (NEXT_PUBLIC_VAPID_PUBLIC_KEY) so the browser can subscribe. The
# subject is a `mailto:` URL push providers use to reach the app owner
# if a push fails. Either VAPID_*_KEY unset disables push delivery — the
# server logs a warning and `/api/v1/push/*` becomes a no-op so dev /
# tests run without keys configured.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@itinly.app

# Frontend (apps/web)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-maps-api-key.apps.googleusercontent.com
# Public half of the VAPID key pair (must match VAPID_PUBLIC_KEY on the
# server). Embedded in the browser bundle so the service worker can
# subscribe. Unset disables the in-app "Enable notifications" affordance.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# OAuth preview-relay configuration. Google's OAuth client only allows
# fixed redirect URIs (no wildcards), but Vercel previews get a unique
# hostname per deploy. To make sign-in work on previews, the web app
# relays the OAuth round-trip through production.
#
# - NEXT_PUBLIC_PROD_ORIGIN: production origin (the only redirect URI
#   registered with Google). Set on BOTH Production and Preview in
#   Vercel — previews use it to know where to relay through; prod
#   compares against it to detect "I'm not the intended target, relay".
#   Leave unset locally — localhost auto-skips the relay.
# - NEXT_PUBLIC_PREVIEW_ORIGIN_PATTERN: anchored regex matching allowed
#   preview origins (full URL incl. scheme). The relay refuses to
#   bounce OAuth codes to anything that doesn't match. Set on
#   Production only — that's where the relay runs. Mirrors the server's
#   CORS_ORIGIN_PATTERN.
NEXT_PUBLIC_PROD_ORIGIN=https://your-app.vercel.app
NEXT_PUBLIC_PREVIEW_ORIGIN_PATTERN=^https://itinly-[a-z0-9-]+-justmarks-projects\.vercel\.app$