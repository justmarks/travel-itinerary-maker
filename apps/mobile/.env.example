# Mobile app environment variables (Expo reads .env automatically)
# Copy to .env and fill in your values.

# Backend API URL.
# Local dev: use your machine's LAN IP, not localhost — "localhost" resolves
# to the device itself, not your dev machine. Find it with `ipconfig` (Windows)
# or `ifconfig` (Mac/Linux). Example: http://192.168.1.42:3001/api/v1
# Production: your Railway backend URL.
EXPO_PUBLIC_API_BASE_URL=http://192.168.x.x:3001/api/v1

# Google OAuth client ID for the *native* Android credential.
# This is a separate credential from the web app — create it at:
# https://console.cloud.google.com/apis/credentials
# Application type: Android
# Package name: com.justmarks.travelitinerarymaker
# SHA-1: run `eas credentials` to get your keystore fingerprint
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
