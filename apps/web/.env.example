# itinly — frontend environment variables (`apps/web`).
# Copy this file to `apps/web/.env.local` and fill in the values for any
# integration you want to enable locally. Empty / missing values are
# tolerated: the build still succeeds and the relevant in-app affordance
# becomes a no-op.

# ─── Backend wiring ──────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Origin used by `metadataBase` for absolute OG image URLs in social
# unfurls + by `app/robots.ts` + `app/sitemap.ts`. Set to the deployed
# origin (e.g. `https://itinly.vercel.app` or `https://itinly.app`).
# Unset locally → Next.js falls back to its own default base.
NEXT_PUBLIC_SITE_URL=https://itinly.app

# ─── Sign-in ─────────────────────────────────────────────────────────────────
# Public half of the primary Google OAuth client (matches GOOGLE_CLIENT_ID
# on the server). Required for legacy Google sign-in. New setups should
# also configure Supabase below — see docs/supabase-auth-setup.md.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Public half of the Gmail OAuth client (matches GOOGLE_GMAIL_CLIENT_ID).
# Powers the in-app "Connect Gmail" CTA. Unset disables that affordance.
NEXT_PUBLIC_GOOGLE_CLIENT_ID_GMAIL=your-gmail-client-id.apps.googleusercontent.com

# ─── Supabase Auth ───────────────────────────────────────────────────────────
# When both are set, the login pages route Google + Microsoft sign-in
# through Supabase Auth instead of the legacy custom Google OAuth flow.
# The anon key is safe to ship in the public bundle — row-level-security
# policies on the Postgres side gate data access. Get both from the
# Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ─── Google Maps (Map tab) ───────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-maps-api-key
# Optional Cloud map ID for styled markers. Defaults to a demo ID when
# unset; safe to leave blank in dev.
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
# Public half of the VAPID key pair on the server. Embedded in the
# browser bundle so the service worker can subscribe. Unset disables the
# in-app "Enable notifications" affordance.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ─── Sentry (browser) ────────────────────────────────────────────────────────
# Browser-side Sentry DSN. Use a DIFFERENT project from the server's
# `SENTRY_DSN` — `NEXT_PUBLIC_` values ship in the static bundle, so
# don't reuse the server DSN here. Unset disables browser error
# reporting (init becomes a no-op).
NEXT_PUBLIC_SENTRY_DSN=

# ─── OAuth preview-relay (Vercel deployments only) ───────────────────────────
# Google's OAuth client only allows fixed redirect URIs, but Vercel
# previews get a unique hostname per deploy. The web app relays the
# OAuth round-trip through production.
#
# NEXT_PUBLIC_PROD_ORIGIN: production origin (the only redirect URI
#   registered with Google). Set on BOTH Production and Preview in
#   Vercel — previews use it to know where to relay through; prod
#   compares against it to detect "I'm not the intended target, relay."
#   Leave unset locally — localhost auto-skips the relay.
NEXT_PUBLIC_PROD_ORIGIN=https://your-app.vercel.app

# NEXT_PUBLIC_PREVIEW_ORIGIN_PATTERN: anchored regex matching allowed
#   preview origins (full URL incl. scheme). The relay refuses to bounce
#   OAuth codes to anything that doesn't match. Set on Production only
#   — that's where the relay runs. Mirrors `CORS_ORIGIN_PATTERN` on the
#   server. Include any stable preview alias (e.g. preview.itinly.app)
#   in the alternation so the relay can bounce through that too.
NEXT_PUBLIC_PREVIEW_ORIGIN_PATTERN=^(https://itinly-[a-z0-9-]+-justmarks-projects\.vercel\.app|https://preview\.itinly\.app)$
