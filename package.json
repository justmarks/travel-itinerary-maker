{
  "name": "travel-itinerary-maker",
  "version": "0.49.5",
  "private": true,
  "description": "Auto-generate travel itineraries from email confirmations",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "lint": "turbo run lint",
    "dev": "turbo run dev",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.9.7",
    "typescript": "^5.8.0"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    },
    "peerDependencyRules": {
      "ignoreMissing": [],
      "allowedVersions": {
        "react": "19",
        "react-dom": "19",
        "@types/react": "19"
      }
    },
    "ignoredBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  }
}
