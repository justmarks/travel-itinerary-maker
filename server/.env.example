# itinly — server environment variables.
# Copy this file to `server/.env` and fill in real values for any feature you
# want to enable locally. Empty / missing values are intentionally tolerated:
# the server skips the corresponding integration rather than refusing to boot.

# ─── Core ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated literal origins allowed by the API.
CORS_ORIGIN=http://localhost:3000
# Optional regex for dynamic origins (e.g. Vercel preview URLs).
# Example: ^https://itinly-[a-z0-9-]+-justmarks-projects\.vercel\.app$
CORS_ORIGIN_PATTERN=

# ─── Google OAuth — primary client ───────────────────────────────────────────
# Used for sign-in, Drive storage, and Calendar sync. Configure this client
# in Google Cloud Console with scopes: openid, email, profile, drive.file,
# calendar. NOT gmail.readonly — Gmail uses a separate client below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Google OAuth — Gmail client ─────────────────────────────────────────────
# Separate OAuth client used only for the restricted `gmail.readonly` scope
# powering the email-scan feature. Splitting Gmail onto its own client lets
# the primary client clear standard verification without the whole app being
# dragged through Google's CASA security assessment. Users who opt into
# email scanning consent to this client separately. Configure this client in
# Google Cloud Console with scopes: openid, email, profile, gmail.readonly.
# Leave both vars unset to disable Gmail scanning entirely (the auth route
# returns 503 and the UI never offers the "Connect Gmail" CTA).
GOOGLE_GMAIL_CLIENT_ID=
GOOGLE_GMAIL_CLIENT_SECRET=

# ─── Microsoft (Azure AD) OAuth client ───────────────────────────────────────
# Used for Supabase Microsoft sign-in AND for Microsoft Graph access to the
# signed-in user's mail (Mail.Read) + calendar (Calendars.ReadWrite). Unlike
# Google, Microsoft's mail + calendar scopes aren't gated behind a CASA-style
# external assessment, so one Azure app registration serves every capability.
#
# Required for the Phase 4b-2 token-refresh path to mint Graph access tokens
# from refresh tokens stored in `connections`. Leave both vars unset to
# disable Microsoft mail + calendar integration entirely (Supabase sign-in
# still works — Supabase has its own copy of these credentials in its
# provider config).
#
# TENANT_ID picks the issuer:
#   common         — multi-tenant (any work / school / personal MS account)
#   consumers      — personal Microsoft accounts only
#   organizations  — work / school accounts only (no personal)
#   <tenant-guid>  — single-tenant (only your Azure AD directory)
#
# Source: Azure portal → App registrations → your itinly app → Overview
# (clientId, tenantId) + Certificates & secrets (clientSecret).
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# ─── Anthropic ───────────────────────────────────────────────────────────────
# Used by the email parser to extract trip segments from email content.
ANTHROPIC_API_KEY=

# ─── Sentry ──────────────────────────────────────────────────────────────────
# DSN for the *server* project. Leave unset in dev/CI to disable error
# reporting entirely. The web app reads its own DSN from
# NEXT_PUBLIC_SENTRY_DSN — do not reuse the server DSN there.
SENTRY_DSN=

# ─── Upstash Redis (optional) ────────────────────────────────────────────────
# When both are set, refresh tokens and share-link metadata persist across
# restarts. Either unset means "Redis disabled" — stores fall back to memory.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 32-byte hex-encoded key for at-rest encryption of refresh tokens written
# to Redis. Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
# Generate once with: npx web-push generate-vapid-keys
# Either key unset disables push delivery (callers degrade to a no-op).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@itinly.app

# ─── Storage backend (phase 1 of the Drive→Supabase migration) ──────────────
# Controls which StorageProvider per-user requests resolve to.
#
#   drive (default) — every user reads/writes their own Google Drive folder,
#     except users in STORAGE_POSTGRES_USERS who are routed to Postgres.
#   postgres — every authenticated user is on Supabase Postgres.
#   memory — dev/test only; one shared in-memory store, no auth.
#
# See docs/backend-migration-plan.md for the full rollout story.
STORAGE_BACKEND=

# Comma-separated user IDs (Google `sub` strings) routed to Postgres even
# when STORAGE_BACKEND=drive. Used for phase 1 dogfooding before the global
# flip. Empty / unset means nobody overrides.
STORAGE_POSTGRES_USERS=

# Postgres connection string. Required when storage involves Postgres
# (mode=postgres OR STORAGE_POSTGRES_USERS is non-empty). Used by:
#   - `pnpm test:integration` and `pnpm bench:routes:postgres`
#   - The running server when storage involves Postgres
#   - `pnpm db:migrate` to apply schema changes
#
# Use `sslmode=require` (not `verify-full`) when going through Supabase's
# Session pooler — the pooler's TLS chain doesn't validate against the
# system root CAs cleanly and `verify-full` fails the handshake. Direct
# Supabase connections + Neon both work with `verify-full`. If in doubt
# on Supabase pooler, omit the sslmode param entirely (defaults to
# require, which encrypts but skips CA verification).
#
# IMPORTANT: from Railway (and most cloud providers), you MUST use
# Supabase's Session pooler URL, NOT the Direct connection URL. Supabase
# Direct resolves to IPv6 only, and Railway's outbound network is IPv4
# only — the connection times out with ENETUNREACH. The Session pooler
# is IPv4-reachable. Find it in Supabase Dashboard → Project Settings →
# Database → Connection string → "Session pooler" tab (port 5432).
#
# Use Session pooler (port 5432) for a long-lived Express server like
# this one. Transaction pooler (port 6543) is serverless-only and drops
# prepared statements between requests, which breaks some Drizzle paths.
#
# Examples:
#   Neon:              postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=verify-full
#   Supabase Session:  postgresql://postgres.<ref>:<pw>@aws-1-us-east-1.pooler.supabase.com:5432/postgres
#   Supabase Direct:   postgresql://postgres:<pw>@db.<ref>.supabase.co:5432/postgres?sslmode=verify-full  ← IPv6, local-only
#   Local:             postgres://postgres@localhost:5432/itinly_dev
#
# Heads-up on the password: Supabase auto-generates passwords containing
# URL-reserved characters (`?`, `@`, `:`, `/`, `#`, `%`, `+`). Either
# URL-encode them in the URL (`?` → `%3F`) or — easier — type a custom
# alphanumeric password when you click "Reset password" in Supabase.
DATABASE_URL=

# ─── Supabase Auth (phase 3 of the Drive→Supabase migration) ────────────────
# When set, `requireAuth` accepts Supabase Auth JWTs in addition to the
# legacy Google access tokens (coexistence). The server only needs the
# project URL — the JWKS endpoint is derived from it. When unset, the
# middleware validates Google tokens only (the legacy path every
# pre-phase-3 client uses).
#
# See docs/supabase-auth-setup.md for the full Supabase project +
# Azure AD app registration setup the providers depend on.
SUPABASE_URL=
