# itinly вЂ” server environment variables.
# Copy this file to `server/.env` and fill in real values for any feature you
# want to enable locally. Empty / missing values are intentionally tolerated:
# the server skips the corresponding integration rather than refusing to boot.

# в”Ђв”Ђв”Ђ Core в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
PORT=3001
NODE_ENV=development

# в”Ђв”Ђв”Ђ CORS в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Comma-separated literal origins allowed by the API.
CORS_ORIGIN=http://localhost:3000
# Optional regex for dynamic origins (e.g. Vercel preview URLs).
# Example: ^https://itinly-[a-z0-9-]+-justmarks-projects\.vercel\.app$
CORS_ORIGIN_PATTERN=

# в”Ђв”Ђв”Ђ Google OAuth вЂ” primary client в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Used for sign-in and Calendar sync. Configure this client in Google Cloud
# Console with scopes: openid, email, profile, calendar. NOT gmail.readonly
# вЂ” Gmail uses a separate client below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# в”Ђв”Ђв”Ђ Google OAuth вЂ” Gmail client в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Separate OAuth client used only for the restricted `gmail.readonly` scope
# powering the email-scan feature. Splitting Gmail onto its own client lets
# the primary client clear standard verification without the whole app being
# dragged through Google's CASA security assessment. Users who opt into
# email scanning consent to this client separately. Configure this client in
# Google Cloud Console with scopes: openid, email, profile, gmail.readonly.
# Leave both vars unset to disable Gmail scanning entirely (the auth route
# returns 503 and the UI never offers the "Connect Gmail" CTA).
GOOGLE_GMAIL_CLIENT_ID=
GOOGLE_GMAIL_CLIENT_SECRET=

# в”Ђв”Ђв”Ђ Microsoft (Azure AD) OAuth client в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Used for Supabase Microsoft sign-in AND for Microsoft Graph access to the
# signed-in user's mail (Mail.Read) + calendar (Calendars.ReadWrite). Unlike
# Google, Microsoft's mail + calendar scopes aren't gated behind a CASA-style
# external assessment, so one Azure app registration serves every capability.
#
# Required for the Phase 4b-2 token-refresh path to mint Graph access tokens
# from refresh tokens stored in `connections`. Leave both vars unset to
# disable Microsoft mail + calendar integration entirely (Supabase sign-in
# still works вЂ” Supabase has its own copy of these credentials in its
# provider config).
#
# TENANT_ID picks the issuer:
#   common         вЂ” multi-tenant (any work / school / personal MS account)
#   consumers      вЂ” personal Microsoft accounts only
#   organizations  вЂ” work / school accounts only (no personal)
#   <tenant-guid>  вЂ” single-tenant (only your Azure AD directory)
#
# Source: Azure portal в†’ App registrations в†’ your itinly app в†’ Overview
# (clientId, tenantId) + Certificates & secrets (clientSecret).
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# в”Ђв”Ђв”Ђ Anthropic в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Used by the email parser to extract trip segments from email content.
ANTHROPIC_API_KEY=

# в”Ђв”Ђв”Ђ Sentry в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# DSN for the *server* project. Leave unset in dev/CI to disable error
# reporting entirely. The web app reads its own DSN from
# NEXT_PUBLIC_SENTRY_DSN вЂ” do not reuse the server DSN there.
SENTRY_DSN=

# в”Ђв”Ђв”Ђ Upstash Redis (optional) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# When both are set, refresh tokens and share-link metadata persist across
# restarts. Either unset means "Redis disabled" вЂ” stores fall back to memory.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 32-byte hex-encoded key for at-rest encryption of refresh tokens written
# to Redis. Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# в”Ђв”Ђв”Ђ Web Push (VAPID) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Generate once with: npx web-push generate-vapid-keys
# Either key unset disables push delivery (callers degrade to a no-op).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@itinly.app

# в”Ђв”Ђв”Ђ Storage backend в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Controls which StorageProvider per-user requests resolve to.
#
#   postgres вЂ” every authenticated user is on Supabase Postgres
#     (production default). Requires DATABASE_URL below.
#   memory вЂ” dev/test only; one shared in-memory store, no auth.
#   unset  вЂ” defaults to `postgres` in production, `memory` in dev.
#
# The pre-Phase-6 `drive` backend (per-user Google Drive storage) was
# removed once the Postgres migration finished вЂ” see
# docs/backend-migration-plan.md.
STORAGE_BACKEND=

# Postgres connection string. Required when storage involves Postgres
# (mode=postgres) OR when SUPABASE_URL is set (Supabase-authed users
# live on Postgres exclusively). Used by:
#   - `pnpm test:integration` and `pnpm bench:routes:postgres`
#   - The running server when storage involves Postgres
#   - `pnpm db:migrate` to apply schema changes
#
# Use `sslmode=require` (not `verify-full`) when going through Supabase's
# Session pooler вЂ” the pooler's TLS chain doesn't validate against the
# system root CAs cleanly and `verify-full` fails the handshake. Direct
# Supabase connections + Neon both work with `verify-full`. If in doubt
# on Supabase pooler, omit the sslmode param entirely (defaults to
# require, which encrypts but skips CA verification).
#
# IMPORTANT: from Railway (and most cloud providers), you MUST use
# Supabase's Session pooler URL, NOT the Direct connection URL. Supabase
# Direct resolves to IPv6 only, and Railway's outbound network is IPv4
# only вЂ” the connection times out with ENETUNREACH. The Session pooler
# is IPv4-reachable. Find it in Supabase Dashboard в†’ Project Settings в†’
# Database в†’ Connection string в†’ "Session pooler" tab (port 5432).
#
# Use Session pooler (port 5432) for a long-lived Express server like
# this one. Transaction pooler (port 6543) is serverless-only and drops
# prepared statements between requests, which breaks some Drizzle paths.
#
# Examples:
#   Neon:              postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=verify-full
#   Supabase Session:  postgresql://postgres.<ref>:<pw>@aws-1-us-east-1.pooler.supabase.com:5432/postgres
#   Supabase Direct:   postgresql://postgres:<pw>@db.<ref>.supabase.co:5432/postgres?sslmode=verify-full  в†ђ IPv6, local-only
#   Local:             postgres://postgres@localhost:5432/itinly_dev
#
# Heads-up on the password: Supabase auto-generates passwords containing
# URL-reserved characters (`?`, `@`, `:`, `/`, `#`, `%`, `+`). Either
# URL-encode them in the URL (`?` в†’ `%3F`) or вЂ” easier вЂ” type a custom
# alphanumeric password when you click "Reset password" in Supabase.
DATABASE_URL=

# в”Ђв”Ђв”Ђ Supabase Auth (phase 3 of the Driveв†’Supabase migration) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# When set, `requireAuth` accepts Supabase Auth JWTs in addition to the
# legacy Google access tokens (coexistence). The server only needs the
# project URL вЂ” the JWKS endpoint is derived from it. When unset, the
# middleware validates Google tokens only (the legacy path every
# pre-phase-3 client uses).
#
# See docs/supabase-auth-setup.md for the full Supabase project +
# Azure AD app registration setup the providers depend on.
SUPABASE_URL=

# в”Ђв”Ђв”Ђ Diagnostic logging в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Each `DEBUG_*=1` toggle enables a focused stream of verbose
# console.log calls; leave unset in production so Railway logs stay
# clean. `console.warn` / `console.error` calls are NOT gated by these вЂ”
# real anomalies always surface.

# Verbose per-step logging from the email-scan pipeline (Gmail fetch,
# parse, dedup, apply). Set while debugging email-scan issues.
DEBUG_EMAIL_SCAN=

# Verbose tracing in `/api/v1/connections` POSTs вЂ” logs
# `prevHadRefreshToken=X nowHasRefreshToken=Y` so you can tell apart
# "row was always tokenless" from "we clobbered a working token"
# without dumping the DB. Adds one extra `findByKey` per POST when
# enabled.
DEBUG_CONNECTIONS=

# Enables the `[calendar-list]` `tokeninfo` diagnostic вЂ” on Google
# calendar 403-scope errors, hits Google's `/tokeninfo` endpoint with
# the user's access token to dump the scopes the token actually
# carries. Off by default because the probe sends the access token
# to an external endpoint; only enable when actively triaging a
# scopes-mismatch incident.
DEBUG_CALENDAR=
