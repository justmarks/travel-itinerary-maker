{
  "name": "@travel-app/server",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:integration": "jest --config jest.integration.config.ts",
    "bench:routes": "ts-node --transpile-only scripts/bench-routes.ts",
    "bench:routes:postgres": "ts-node --transpile-only scripts/bench-routes.ts --postgres",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.93.0",
    "@sentry/node": "^10.51.0",
    "@travel-app/shared": "workspace:*",
    "@upstash/redis": "^1.37.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.0",
    "googleapis": "^171.4.0",
    "html-to-text": "^9.0.5",
    "mailparser": "^3.9.8",
    "nanoid": "^5.1.11",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.13.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/html-to-text": "^9.0.4",
    "@types/jest": "^29.5.0",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^7.2.0",
    "@types/web-push": "^3.6.4",
    "drizzle-kit": "^0.31.10",
    "jest": "^29.7.0",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.0"
  }
}
